generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Severity {
  informational
  low
  medium
  high
  critical
}

enum EvidenceType {
  http
  text
  terminal
  log
  file
  note
  screenshot
  request
  response
}

enum ReportStatus {
  draft
  generated
  archived
}

enum ThemePreference {
  light
  dark
  system
}

enum ReportBrandingMode {
  issuer
  client
  none
}

enum ActivityEntityType {
  company
  assessment
  threat
  evidence
  report
  settings
}

model Company {
  id           String   @id
  name         String
  description  String?
  website      String?
  contactName  String?
  contactEmail String?
  logoUrl      String?
  logoPath     String?
  footerText   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessments Assessment[]

  @@index([name])
}

model Assessment {
  id              String    @id
  companyId       String
  title           String
  description     String?
  scope           String?
  status          String
  startedAt       String?
  completedAt     String?
  applicationName String?
  environment     String?
  assessmentType  String?
  overallRisk     Severity?
  owaspTaxonomyVersion String @default("2025")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  threats  Threat[]
  evidence Evidence[]
  reports  Report[]

  @@index([companyId])
  @@index([companyId, updatedAt])
  @@index([status])
}

model Threat {
  id                String   @id
  assessmentId      String
  title             String
  description       String
  severity          Severity
  strideCategories  Json
  status            String
  owaspCategoryCode String?
  customCategory    String?
  affectedAsset     String?
  impact            String?
  recommendation    String?
  remediation       String?
  observation       String?
  reproductionSteps String?
  affectedComponent String?
  affectedEndpoint  String?
  risk              String?
  references        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assessment    Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceLinks EvidenceThreat[]
  reportLinks   ReportThreat[]

  @@index([assessmentId])
  @@index([assessmentId, updatedAt])
  @@index([status])
  @@index([severity])
}

model Evidence {
  id                 String             @id
  assessmentId       String
  type               EvidenceType
  title              String
  description        String?
  content            String?
  fileName           String?
  filePath           String?
  storageKey         String?
  mimeType           String?
  attachmentSizeBytes Int?
  capturedAt         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  assessment   Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  threatLinks  EvidenceThreat[]
  httpExchanges EvidenceExchange[]

  @@index([assessmentId])
  @@index([assessmentId, createdAt])
  @@index([capturedAt])
}

model EvidenceExchange {
  id         String   @id
  evidenceId String
  position   Int
  request    Json
  response   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([evidenceId, position])
  @@index([evidenceId])
}

model Report {
  id               String       @id
  assessmentId     String
  title            String
  status           ReportStatus @default(draft)
  latestVersion    Int          @default(0)
  executiveSummary String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assessment      Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  selectedThreats ReportThreat[]

  @@index([assessmentId])
  @@index([assessmentId, createdAt])
  @@index([status])
}

model EvidenceThreat {
  evidenceId String
  threatId   String

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  threat   Threat   @relation(fields: [threatId], references: [id], onDelete: Restrict)

  @@id([evidenceId, threatId])
  @@index([threatId])
}

model ReportThreat {
  reportId String
  threatId String

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  threat Threat @relation(fields: [threatId], references: [id], onDelete: Restrict)

  @@id([reportId, threatId])
  @@index([threatId])
}

model Activity {
  id         String             @id
  entityType ActivityEntityType
  entityId   String?
  action     String
  message    String
  createdAt  DateTime           @default(now())

  @@index([entityType, createdAt])
  @@index([entityId])
}

model Settings {
  id                         String              @id
  organisationName           String?
  consultantName             String?
  consultantEmail            String?
  issuerLogoId               String?
  defaultReportTitle         String?
  defaultSeverity            Severity
  theme                      ThemePreference
  dateFormat                 String
  reportFooterText           String?
  reportConfidentialityLabel String?
  methodology                String?
  reportStyle                String?
  includeEvidence            Boolean?
  confidentialReports        Boolean?
  allowedBrandingModes       Json?
  defaultBrandingMode        ReportBrandingMode?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
}
