{
  "name": "appsec-report-builder",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=24 <25"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm run api:dev",
    "api:dev": "tsx watch server/index.ts",
    "api:start": "node dist-server/server/index.js",
    "db:validate": "node scripts/prisma-command.mjs validate",
    "db:generate": "node scripts/prisma-command.mjs generate",
    "db:migrate": "node scripts/prisma-command.mjs migrate dev",
    "db:seed": "node scripts/prisma-command.mjs db seed",
    "db:reset": "node scripts/prisma-command.mjs migrate reset --force && node scripts/prisma-command.mjs db seed",
    "db:studio": "node scripts/prisma-command.mjs studio",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "prepare": "git config core.hooksPath .husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test:frontend": "vitest run --project frontend",
    "test:backend": "vitest run --project backend",
    "test:assessment": "vitest run --project backend src/domain/schemas/assessment.schema.vitest.test.ts server/database/repositories/assessment.repository.vitest.test.ts server/database/repositories/assessment.repository.integration.vitest.test.ts server/http/assessments.route.integration.vitest.test.ts server/http/assessments.route.commands.integration.vitest.test.ts",
    "test:threat": "vitest run --project backend src/domain/schemas/threat.schema.vitest.test.ts server/database/repositories/threat.repository.vitest.test.ts server/database/repositories/threat.repository.integration.vitest.test.ts",
    "test:threat-api": "tsx server/http/threats.route.integration.test.ts && vitest run --project backend server/http/threats.route.integration.gaps.vitest.test.ts",
    "test:threat-workflow": "vitest run --project frontend src/app/pages/assessmentDetails/assessmentDetails.threatWorkflow.vitest.test.tsx src/app/pages/assessmentDetails/assessmentDetails.threatForm.composition.vitest.test.tsx src/app/pages/assessmentDetails/components/assessmentFindingsSection.component.vitest.test.tsx",
    "test:evidence": "vitest run --project backend src/domain/schemas/evidence.schema.vitest.test.ts server/database/repositories/evidence.repository.vitest.test.ts server/database/repositories/evidence.repository.integration.vitest.test.ts",
    "test:evidence-api": "tsx server/http/evidence.route.integration.test.ts && vitest run --project backend server/http/evidence.route.integration.gaps.vitest.test.ts",
    "test:evidence-workflow": "vitest run --project frontend src/app/pages/assessmentDetails/evidence/evidence.workflow.vitest.test.tsx src/app/pages/assessmentDetails/evidence/section/EvidenceSection.states.vitest.test.tsx src/app/pages/assessmentDetails/evidence/section/EvidenceSection.flows.vitest.test.tsx src/app/pages/assessmentDetails/evidence/section/EvidenceSection.edge.vitest.test.tsx",
    "validate": "npm run db:validate && npm run format:check && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,jsx,tsx}": [
      "node ./node_modules/eslint/bin/eslint.js --fix",
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{json,jsonc,md,yml,yaml}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0",
    "styled-components": "^6.1.15",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "storybook": "^8.6.18",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.9"
  }
}
