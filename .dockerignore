# Version control and editor files
.git
.github
.vscode
.idea

# Local dependencies and build outputs
node_modules
dist
dist-server
coverage
storybook-static
*.tsbuildinfo

# Local configuration and credentials
.env
.env.*
!.env.example
.npmrc
*.pem
*.key
*.crt
*.pfx

# Local Docker configuration and secrets
docker/**/*.local
docker/**/secrets/**

# Runtime data must not be baked into the image
prisma/*.db
prisma/*.db-*
*.sqlite
*.sqlite3
uploads

# Logs and temporary files
*.log
logs
tmp
temp
.tmp

# Files not required to build the runtime application
docs
prototype
**/*.test.*
**/*.spec.*
